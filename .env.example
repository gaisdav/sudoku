# Копируйте в .env и подставьте свои значения.
# Файл .env не коммитится (.gitignore).

# AdMob (тестовые ID для разработки — можно оставить для локального запуска)
# Боевые ID задавайте здесь для релиза или передавайте через --dart-define при сборке.
ADMOB_APP_ID_ANDROID=ca-app-pub-3940256099942544~3347511713
ADMOB_APP_ID_IOS=ca-app-pub-3940256099942544~1458002511
ADMOB_BANNER_ID_ANDROID=ca-app-pub-3940256099942544/6300978111
ADMOB_BANNER_ID_IOS=ca-app-pub-3940256099942544/2934735716
ADMOB_INTERSTITIAL_ID_ANDROID=ca-app-pub-3940256099942544/1033173712
ADMOB_INTERSTITIAL_ID_IOS=ca-app-pub-3940256099942544/4411468910
ADMOB_REWARDED_ID_ANDROID=ca-app-pub-3940256099942544/5224354917
ADMOB_REWARDED_ID_IOS=ca-app-pub-3940256099942544/1712485313
ADMOB_APP_OPEN_ID_ANDROID=ca-app-pub-3940256099942544/9257395921
ADMOB_APP_OPEN_ID_IOS=ca-app-pub-3940256099942544/5575463023

# --- Параметры управления рекламой (Interstitial, App Open) ---
# При отладке можно ставить меньшие значения (например 0 и 1), чтобы реклама показывалась чаще.

# Interstitial: минимальный интервал (минуты) между любыми межстраничными показами.
INTERSTITIAL_MIN_INTERVAL_MINUTES=6
# Interstitial: дополнительный минимальный интервал (минуты) для кнопок Restart в Game over / You won.
INTERSTITIAL_RESTART_MIN_INTERVAL_MINUTES=3
# Interstitial: показывать каждое N-е нажатие «Продолжить» (Continue).
INTERSTITIAL_EVERY_NTH_CONTINUE=2
# Interstitial: каждое N-е нажатие на сложность в блоке «Start new game» на главной.
INTERSTITIAL_EVERY_NTH_START_NEW_GAME=2
# Interstitial: каждое N-е нажатие «New game» в шапке экрана игры.
INTERSTITIAL_EVERY_NTH_NEW_GAME_IN_HEADER=2
# Interstitial: каждый N-й выход в меню (назад, Back to menu в Game over/You won — считаются вместе).
INTERSTITIAL_EVERY_NTH_BACK_TO_MENU=2
# Interstitial: каждое N-е нажатие по переключателю Notes.
INTERSTITIAL_EVERY_NTH_NOTES=3

# App Open: минимальное время (секунды) в фоне, чтобы возврат в приложение считался «открытием».
APP_OPEN_RESUME_MIN_BACKGROUND_SECONDS=60
# App Open: показывать каждое N-е возвращение из фона (resume).
APP_OPEN_EVERY_NTH_RESUME=3
# App Open: показывать каждое N-е полное открытие приложения (cold start).
APP_OPEN_EVERY_NTH_COLD_START=3
